generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum BusStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RouteStatus {
  ACTIVE
  INACTIVE
}
model User {
  id          String   @id @default(uuid())
  companyName String
  email       String   @unique
  password    String
  createdAt   DateTime @default(now())

  buses  Bus[]
  routes Route[]
  trips  Trip[]

  staff Staff[]
}

model Bus {
  id         String    @id @default(uuid())
  busNumber  String
  type       String
  capacity   Int
  status     BusStatus @default(ACTIVE)
  driverName String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  trips Trip[]

  @@unique([id, userId]) // 🔥 required for secure queries
  @@unique([busNumber, userId]) // 🔥 optional but recommended
  @@index([userId])
}

model Route {
  id        String   @id @default(uuid())
  from      String
  to        String
  distance  Int
  status   RouteStatus @default(ACTIVE)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  trips Trip[]

  @@index([userId])
}

model Trip {
  id   String   @id @default(uuid())
  date DateTime

  income  Float
  expense Float

  // 🔥 ADD THESE
  travelTime Int? // in minutes
  notes      String?

  // 🔥 Optional but powerful
  driverId String?

  createdAt DateTime @default(now())

  busId   String
  routeId String
  userId  String

  bus   Bus   @relation(fields: [busId], references: [id])
  route Route @relation(fields: [routeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([busId])
  @@index([routeId])
}

model Staff {
  id        String   @id @default(uuid())
  name      String
  role      String // Driver, Conductor, Helper etc
  phone     String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
}
