generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BusStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum RouteStatus {
  ACTIVE
  INACTIVE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id          String   @id @default(uuid())

  // Company Info
  companyName String

  // Auth
  email       String   @unique
  password    String

  // Profile Info
  fullName    String?
  phone       String?
  address     String?
  avatar      String?
  role        String   @default("admin")

  // Security
  isActive    Boolean  @default(true)
  lastLogin   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relations
  buses        Bus[]
  routes       Route[]
  trips        Trip[]
  staff        Staff[]
  transactions Transaction[]
  bookings     Booking[]
}



model Bus {
  id         String    @id @default(uuid())
  busNumber  String
  type       String
  capacity   Int
  status     BusStatus @default(ACTIVE)
  driverName String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  trips Trip[]

  transactions Transaction[]
  Booking      Booking[]

  @@unique([id, userId]) // 🔥 required for secure queries
  @@unique([busNumber, userId]) // 🔥 optional but recommended
  @@index([userId])
}

model Route {
  id        String      @id @default(uuid())
  from      String
  to        String
  distance  Int
  status    RouteStatus @default(ACTIVE)
  createdAt DateTime    @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  trips Trip[]

  transactions Transaction[]
  Booking      Booking[]

  @@index([userId])
}

model Trip {
  id   String   @id @default(uuid())
  date DateTime

  income  Float
  expense Float

  passengers Int? // ✅ SIMPLE & CORRECT

  travelTime Int?
  notes      String?

  driverId String?

  createdAt DateTime @default(now())

  busId   String
  routeId String
  userId  String

  bus   Bus   @relation(fields: [busId], references: [id])
  route Route @relation(fields: [routeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([busId])
  @@index([routeId])
}

model Staff {
  id        String   @id @default(uuid())
  name      String
  role      String // Driver, Conductor, Helper etc
  phone     String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  @@index([userId])
}

enum TransactionType {
  income
  expense
}

model Transaction {
  id String @id @default(cuid())

  type     TransactionType
  category String
  amount   Float

  paymentMethod String?
  description   String?

  passengers Int      @default(0)
  date       DateTime
  createdAt  DateTime @default(now())

  // 🔗 Relations (optional links)
  busId   String?
  routeId String?
  staffId String?

  createdById String

  // 🔗 Relations
  bus   Bus?   @relation(fields: [busId], references: [id])
  route Route? @relation(fields: [routeId], references: [id])
  staff Staff? @relation(fields: [staffId], references: [id])

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@index([busId])
  @@index([routeId])
  @@index([staffId])
  @@index([date])
}

model Booking {
  id String @id @default(uuid())

  // BOOKING INFO
  bookingCode   String  @unique
  passengerName String
  phone         String?
  email         String?

  // SEAT / TICKET
  seats Int @default(1)

  // PAYMENT
  amount        Float
  paymentMethod String?

  // STATUS
  status BookingStatus @default(PENDING)

  // DATE
  journeyDate DateTime
  bookingDate DateTime @default(now())

  // OPTIONAL NOTES
  note String?

  // RELATIONS
  busId       String?
  routeId     String?
  createdById String

  bus   Bus?   @relation(fields: [busId], references: [id])
  route Route? @relation(fields: [routeId], references: [id])

  createdBy User @relation(fields: [createdById], references: [id])

  // TIMESTAMPS
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
